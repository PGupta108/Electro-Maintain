# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:3000

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Free MongoDB Atlas: https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/electromaintain

# ─── JWT AUTH ─────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── EMAIL (Nodemailer via Gmail) ─────────────────────────────────────────────
# Use Gmail App Password — NOT your real Gmail password
# Guide: https://support.google.com/accounts/answer/185833
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_16_char_gmail_app_password
EMAIL_FROM=ElectroMaintain <youremail@gmail.com>

# ─── ANTHROPIC AI (OPTIONAL — for AI-enhanced smart reminders) ────────────────
# Get free API key at: https://console.anthropic.com
# If this is left blank, the system still works using the built-in knowledge base.
# If filled in, it uses Claude AI to generate extra device-specific reminders.
GEMINI_API_KEY=sk-ant-your-key-here